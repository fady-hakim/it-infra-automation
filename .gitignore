override.tf.json
*_override.tf
*_override.tf.json

# PowerShell output folders
Reports/
*.log
Transcript*.log

# CSV reports generated by scripts
*-report-*.csv
*-audit-*.csv
*-alerts-*.csv

# Editor / OS
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo
*~
